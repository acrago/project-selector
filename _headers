# Cache hashed assets for 2 weeks — the content hash in the filename changes on
# every build, so browsers will always fetch new files when the code changes.
/*.bundle.js
  Cache-Control: public, max-age=1209600

/*.bundle.css
  Cache-Control: public, max-age=1209600

/*.css
  Cache-Control: public, max-age=1209600

# HTML should always be revalidated so users get the latest entry point
/*.html
  Cache-Control: no-cache

/
  Cache-Control: no-cache
