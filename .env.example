# Development server configuration
# Copy this file to .env and modify as needed

# PORT - Port for the development server (default: 9000)
PORT=9000

# Prototype Appearance Configuration

# GENERIC_LOGO - Set to 'true' to use generic "AI Platform" text instead of branded logo
# Default: false (shows branded logo)
GENERIC_LOGO=false

# PROTOTYPE_BAR - Set to 'false' to hide the orange "UXD PROTOTYPE" banner at the top
# Default: true (shows the banner)
PROTOTYPE_BAR=true

# DEFAULT_FIDELITY - Set the default fidelity mode ('high' or 'low')
# Default: high (if not set)
# Note: URL query parameter ?fidelity=low or ?fidelity=high will override this
DEFAULT_FIDELITY=high

# GITLAB_TOKEN - GitLab Personal Access Token for fork switcher and (in CI) fork descriptions
# Create at: https://gitlab.cee.redhat.com/-/user_settings/personal_access_tokens (read_api scope)
# Do not commit real values; copy .env.example to .env and set your token locally
GITLAB_TOKEN=your_gitlab_token_here

# MAAS_API_KEY - For Discussions "Summarize" (local dev) and fork description generation (CI)
# Get from your MaaS application; do not commit. Copy to .env for local summarization.
MAAS_API_KEY=your_maas_api_key_here

# MAAS_ENDPOINT_URL - (Optional) MaaS endpoint for summarization; defaults to Llama 3.2 3B if unset
# MAAS_ENDPOINT_URL=https://your-maas-endpoint.example.com

# SUMMARIZE_API_URL - (Production) Full URL of the discussions summarization endpoint (e.g. Cloudflare Worker).
# Set in GitLab CI/CD variables when building for prod so Summarize works on the deployed site. Leave unset for local dev (uses dev server proxy).
# SUMMARIZE_API_URL=https://rhoai-discussions-summarize.<subdomain>.workers.dev

# GitLab Commenting System (OAuth PKCE)
# Register an OAuth app at https://gitlab.cee.redhat.com/-/profile/applications
# Uncheck "Confidential", set scope to "api", add redirect URIs for localhost and GitLab Pages
VITE_GITLAB_CLIENT_ID=your_application_id_here
VITE_GITLAB_BASE_URL=https://gitlab.cee.redhat.com
VITE_GITLAB_PROJECT_PATH=uxd/prototypes/rhoai
